{
  "manifest_version": 3,
  "name": "Ticketmaster+ Cookie Harvester",
  "version": "5.23.25",
  "author": "Sadman Habib",
  "description": "Cookie Harvester for tmpt cookies",
  "permissions": ["cookies", "scripting", "activeTab", "tabs", "storage"],
  "host_permissions": [
    "*://*.ticketmaster.com/*",
    "*://auth.ticketmaster.com/*",
    "*://identity.ticketmaster.com/*",
    "http://127.0.0.1:18731/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Ticketmaster+ Cookie Harvester",
    "default_icon": {
      "16": "icons/16.png",
      "32": "icons/32.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    }
  },
  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  }
}
